# =============================================
# Filecoin Synapse CLI - Environment Variables
# =============================================

# Your wallet private key (with or without 0x prefix)
WALLET_PRIVATE_KEY=0xyour_private_key_here

# Network: "calibration" (testnet) or "mainnet"
NETWORK=calibration

# Optional: GLIF API token for higher rate limits
# Get one at https://api.node.glif.io
# GLIF_TOKEN=your_glif_token_here

# Optional: Enable CDN for faster downloads (true/false)
WITH_CDN=true
