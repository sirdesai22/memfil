# =============================================
# Episodes Marketplace Client (memfil) - Environment Variables
# =============================================

# Your wallet private key (with or without 0x prefix)
# Also accepts PRIVATE_KEY (filecoin-pin convention)
# Used for: x402 payments (buy-agent, buy-memory) and Filecoin uploads
WALLET_PRIVATE_KEY=0xyour_private_key_here

# Marketplace API base URL (for search, buy-agent, buy-memory)
EPISODES_API_URL=http://localhost:3000

# Network: "calibration" (testnet) or "mainnet" (for Filecoin upload only)
NETWORK=calibration

# Optional: Filecoin RPC WebSocket URL (overrides NETWORK)
# Calibration: wss://wss.calibration.node.glif.io/apigw/lotus/rpc/v1
# Mainnet: wss://wss.node.glif.io/apigw/lotus/rpc/v1
# RPC_URL=wss://...
