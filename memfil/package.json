{
  "name": "filecoin-synapse-cli",
  "version": "1.0.0",
  "description": "CLI tool for uploading and downloading files from Filecoin via Synapse SDK",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "synapse-cli": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "upload": "tsx src/index.ts upload",
    "download": "tsx src/index.ts download",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@filoz/synapse-sdk": "latest",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "ethers": "^6.13.0",
    "ora": "^8.0.1",
    "viem": "^2.46.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
